# Coolify environment variables for Crawl4AI.
# Put the real values in Coolify's Environment Variables panel.

# LiteLLM should expose an OpenAI-compatible /v1 endpoint.
# In this WSL Coolify layout, avoid the public Cloudflare URL from app containers.
# A local bridge can expose LiteLLM at host.docker.internal:14000.
OPENAI_BASE_URL=http://host.docker.internal:14000/v1

# Use a LiteLLM virtual key or master key. Do not commit the real value.
OPENAI_API_KEY=sk-your-litellm-key

# The model name must exist in LiteLLM. Keep the openai/ prefix so Crawl4AI routes through LiteLLM.
LLM_PROVIDER=openai/aiclient-gemini-2-5-flash

# Deterministic extraction is usually better for crawler pipelines.
LLM_TEMPERATURE=0

# Keep task data bounded in the bundled Redis instance.
REDIS_TASK_TTL=3600

# Required for the current WSL Coolify proxy layout, where Traefik reaches apps through host ports.
CRAWL4AI_HOST_PORT=11235

# Leave disabled unless you explicitly need Crawl4AI hooks.
CRAWL4AI_HOOKS_ENABLED=false

# Optional production hardening. Health checks remain public.
CRAWL4AI_SECURITY_ENABLED=false
CRAWL4AI_JWT_ENABLED=false
CRAWL4AI_API_TOKEN=
CRAWL4AI_TRUSTED_HOSTS=*
CRAWL4AI_RATE_LIMIT=1000/minute
CRAWL4AI_RATE_LIMIT_STORAGE_URI=memory://
CRAWL4AI_MAX_PAGES=20

# Optional image build controls.
INSTALL_TYPE=default
ENABLE_GPU=false
